rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // În acest mediu, uneori legătura dintre Storage și Firestore ID-ul bazei de date custom poate fi lentă.
    // Folosim o logică mai simplă pentru a asigura funcționarea.

    // 1. MATERIALE (Acces Public Citire, Doar Auth Scrierea)
    match /courses/{courseId}/materials/{allPaths=**} {
      allow read: if true; 
      allow write: if request.auth != null; 
    }

    // 2. TEME (Acces Public Citire, Doar Auth Scrierea)
    match /assignments/{assignmentId}/submissions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. PROFILE / GENERAL
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
