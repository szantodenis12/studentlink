{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and academic record",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "professor", "admin"] },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "academicData": {
          "type": "object",
          "properties": {
            "enrolledCourses": { "type": "array", "items": { "type": "string" } },
            "completedCourses": { "type": "array", "items": { "type": "string" } },
            "grades": { "type": "object" },
            "strengths": { "type": "array", "items": { "type": "string" } },
            "careerRecommendations": { "type": "string" }
          }
        },
        "rating": { "type": "number" },
        "mentorshipPrice": { "type": "number" },
        "mentorshipSubjects": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Academic course details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "professorId": { "type": "string" },
        "professorName": { "type": "string" },
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "professorId"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Homework or project task for a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "title", "dueDate"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student submission for an assignment",
      "type": "object",
      "properties": {
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "grade": { "type": "number" },
        "feedback": { "type": "string" },
        "feedbackFileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "graded"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assignmentId", "studentId", "fileUrl"]
    },
    "Post": {
      "title": "Community Post",
      "description": "Social post in the student community",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content"]
    },
    "Meeting": {
      "title": "Study Meeting",
      "description": "Group study event",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["online", "physical"] },
        "location": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["creatorId", "title", "type", "dateTime"]
    },
    "Quiz": {
      "title": "AI Generated Quiz",
      "description": "Assessment generated by AI from course materials",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctIndex": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["courseId", "questions"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notification for user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Academic courses"
    },
    "courses/{courseId}/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments within a course"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student homework submissions"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Community posts"
    },
    "meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Study meetings"
    },
    "quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "AI-generated quizzes"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
